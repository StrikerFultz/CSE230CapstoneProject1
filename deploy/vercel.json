{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python", "config": { "maxLambdaSize": "50mb" } },
    { "src": "api/emulator.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/emulator",  "dest": "api/emulator.js" },
    { "src": "/api/(.*)",      "dest": "api/index.py" },
    { "src": "/pkg/(.*)",      "dest": "/public/pkg/$1" },
    { "src": "/(.*)",          "dest": "/public/$1" }
  ]
}